# Which provider to use: "anthropic" or "openai"
# ("openai" also works for Groq / OpenRouter - just change OPENAI_BASE_URL)
AI_PROVIDER=anthropic

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# --- OpenAI-compatible (OpenAI, Groq, OpenRouter) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Groq example:      https://api.groq.com/openai/v1   (model: llama-3.1-8b-instant)
# OpenRouter example: https://openrouter.ai/api/v1     (model: meta-llama/llama-3.1-8b-instruct:free)
OPENAI_BASE_URL=https://api.openai.com/v1

PORT=8787
